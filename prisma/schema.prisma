generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model manual_label {
  reason         String?
  metadata_id    BigInt         @id
  eligible       Boolean
  video_metadata video_metadata @relation(fields: [metadata_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model playlist {
  id            String          @id
  owner_id      String?
  thumbnail     String?
  name          String?
  description   String?
  last_accessed DateTime?       @db.Date
  playlist_item playlist_item[]
}

model playlist_item {
  id             Int            @id @default(autoincrement())
  playlist_id    String
  metadata_id    BigInt
  video_metadata video_metadata @relation(fields: [metadata_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  playlist       playlist       @relation(fields: [playlist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model video_metadata {
  video_id             String
  thumbnail            String
  title                String
  uploader             String
  uploader_id          String
  upload_date          DateTime         @db.Date
  duration             Int?
  platform             String
  recent               Boolean
  searchable           Boolean?
  id                   BigInt           @id @default(autoincrement())
  source               BigInt?
  ballot_item          ballot_item[]
  manual_label         manual_label?
  playlist_item        playlist_item[]
  video_metadata       video_metadata?  @relation("video_metadataTovideo_metadata", fields: [source], references: [id], onUpdate: NoAction)
  other_video_metadata video_metadata[] @relation("video_metadataTovideo_metadata")

  @@unique([video_id, platform])
}

model user {
  id          String        @id
  ballot_item ballot_item[]
}

model label_config {
  name    String
  type    String
  details String
  trigger String @id
}

model ballot_item {
  user_id        String
  creation_date  DateTime       @db.Timestamp(6)
  index          Int
  metadata_id    BigInt
  video_metadata video_metadata @relation(fields: [metadata_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           user           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, index])
}
